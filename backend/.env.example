# Flask Configuration
FLASK_ENV=development
JWT_SECRET_KEY=your-secret-key-here-change-in-production
PORT=5000

# API Keys
OPENAI_API_KEY=sk-your-openai-api-key-here
GROQ_API_KEY=gsk_your-groq-api-key-here

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.xxxxx.mongodb.net/pharmaguard?retryWrites=true&w=majority

# Frontend URL (for CORS)
# Development: leave empty or unset (allows all origins)
# Production: set to your deployed frontend URL
# Multiple URLs: separate with commas (e.g., https://app.com,https://www.app.com)
# FRONTEND_URL=https://your-frontend-url.vercel.app
