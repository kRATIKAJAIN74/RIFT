# Frontend Environment Variables

# API Base URL - Points to your backend server
# Local development (default)
VITE_API_URL=http://localhost:5000

# Production - Update this with your deployed backend URL
# Example for Render: VITE_API_URL=https://rift-backend-xyz.onrender.com
# Example for Heroku: VITE_API_URL=https://rift-pharma-backend.herokuapp.com
